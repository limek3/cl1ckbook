# Render Free / Production
NODE_VERSION=22.16.0
NEXT_TELEMETRY_DISABLED=1

# IMPORTANT: first use Render URL. After custom domain works, replace with https://кликбук.рф
APP_URL=https://your-service.onrender.com
NEXT_PUBLIC_APP_URL=https://your-service.onrender.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Optional alias if older code/env uses it
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
DATABASE_URL=postgresql://...

# App secrets
KEY_VAULTS_SECRET=replace_with_long_random_secret
CRON_SECRET=
CLICKBOOK_DISABLE_SINGLE_WORKSPACE_REPAIR=

# Telegram
TELEGRAM_BOT_TOKEN=123456:telegram_bot_token
TELEGRAM_WEBHOOK_SECRET=replace_with_long_random_secret
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_SUPPORT_CHAT_ID=
NEXT_PUBLIC_SUPPORT_TELEGRAM_URL=https://t.me/your_support

# VK OAuth / Bot
VK_ID_CLIENT_ID=
VK_ID_CLIENT_SECRET=
VK_ID_REDIRECT_URI=https://your-service.onrender.com/api/auth/vk/callback
VK_ID_SCOPE=
VK_CLIENT_ID=
VK_CLIENT_SECRET=
VK_REDIRECT_URI=
VK_SCOPE=
VK_BOT_GROUP_ID=
NEXT_PUBLIC_VK_BOT_GROUP_ID=
VK_BOT_SCREEN_NAME=
NEXT_PUBLIC_VK_BOT_SCREEN_NAME=
VK_BOT_ACCESS_TOKEN=
VK_BOT_SECRET=
VK_BOT_CONFIRMATION_CODE=
VK_GROUP_ID=
VK_GROUP_ACCESS_TOKEN=
VK_GROUP_SCREEN_NAME=
VK_CALLBACK_SECRET=
VK_CALLBACK_CONFIRMATION_CODE=
