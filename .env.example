# Supabase public client values
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Supabase server values. Never expose these in client code.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
DATABASE_URL=postgresql://postgres.xxx:password@xxx.pooler.supabase.com:6543/postgres

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional maps
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=

# App secrets
KEY_VAULTS_SECRET=replace_with_long_random_secret

# Telegram support reports
TELEGRAM_BOT_TOKEN=
TELEGRAM_SUPPORT_CHAT_ID=
NEXT_PUBLIC_SUPPORT_TELEGRAM_URL=https://t.me/your_username

# Telegram bot auth
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

# Optional: protect /api/cron/reminders if you call it manually
CRON_SECRET=

# OAuth providers are enabled in Supabase Dashboard -> Authentication -> Providers.
# Google and VK use the same callback URL:
# https://YOUR_DOMAIN/auth/callback

# Billing checkout links. Put real payment provider URLs here (YooKassa/CloudPayments/Stripe/etc.).
CLICKBOOK_CHECKOUT_PRO_MONTHLY_URL=
CLICKBOOK_CHECKOUT_PRO_YEARLY_URL=
CLICKBOOK_CHECKOUT_STUDIO_MONTHLY_URL=
CLICKBOOK_CHECKOUT_STUDIO_YEARLY_URL=
CLICKBOOK_CHECKOUT_PREMIUM_MONTHLY_URL=
CLICKBOOK_CHECKOUT_PREMIUM_YEARLY_URL=
CLICKBOOK_BILLING_PORTAL_URL=
CLICKBOOK_BILLING_WEBHOOK_SECRET=
